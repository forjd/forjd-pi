{
  "name": "forjd-pi",
  "version": "0.1.0",
  "description": "Forjd extension pack for the pi coding agent, starting with a high-level Git diff sidebar.",
  "type": "module",
  "author": "Forjd",
  "homepage": "https://github.com/forjd/forjd-pi#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forjd/forjd-pi.git"
  },
  "bugs": {
    "url": "https://github.com/forjd/forjd-pi/issues"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-coding-agent"
  ],
  "license": "MIT",
  "files": [
    "extensions",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md"
  ],
  "scripts": {
