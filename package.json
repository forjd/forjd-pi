{
  "name": "forjd-pi",
  "version": "0.1.0",
  "description": "Forjd package set for the pi coding agent with a Git diff sidebar, subagents, todo tracking, and structured questions.",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "author": "Forjd",
  "homepage": "https://github.com/forjd/forjd-pi#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forjd/forjd-pi.git"
  },
  "bugs": {
    "url": "https://github.com/forjd/forjd-pi/issues"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "subagents",
    "todo"
  ],
  "license": "MIT",
  "files": [
    "extensions",
    "packages",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "pi": {
    "extensions": [
      "./extensions",
      "./packages/pi-subagents/src/extension/index.ts",
      "./packages/rpiv-todo/index.ts",
      "./packages/rpiv-ask-user-question/index.ts"
    ],
    "skills": [
      "./packages/pi-subagents/skills"
    ],
    "prompts": [
      "./packages/pi-subagents/prompts"
    ]
  },
  "dependencies": {
    "@juicesharp/rpiv-config": "^1.12.0",
    "@juicesharp/rpiv-i18n": "^1.12.0",
    "jiti": "^2.7.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "^0.74.0",
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0",
    "@types/node": "^22.15.29",
    "typebox": "^1.1.24",
    "typescript": "^5.8.3"
  }
}
